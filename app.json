{
  "expo": {
    "name": "BQ Prüfung",
    "slug": "bq-pruefung",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3755B4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bqpruefung.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "BQ Prüfung",
        "NSUserTrackingUsageDescription": "Diese App verwendet kein Tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3755B4"
      },
      "package": "com.bqpruefung.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
